{
  "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Loading caveman mode...",
          "command": "node .claude/hooks/caveman/caveman-activate.js",
          "timeout": 5
        }
      ],
      "_apm_source": "caveman"
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Installing rtk PATH shim...",
          "command": ".claude/hooks/rtk/rtk-shim-install.sh",
          "timeout": 5
        }
      ],
      "_apm_source": "rtk"
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Tracking caveman mode...",
          "command": "node .claude/hooks/caveman/caveman-mode-tracker.js",
          "timeout": 5
        }
      ],
      "_apm_source": "caveman"
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/rtk/rtk-hook-wrapper.sh hook claude"
        }
      ],
      "_apm_source": "rtk"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/rtk/rtk-rewrite-extra.sh"
        }
      ],
      "_apm_source": "rtk"
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "python3 .claude/hooks/rules-on-create/rules_on_create.py",
          "timeout": 10
        }
      ],
      "_apm_source": "rules-on-create"
    }
  ]
}
